name: titanic_mlproject

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_path:
        type: str
        default: "titanic_preprocessing/titanic_preprocessing.csv"
      n_estimators:
        type: int
        default: 100
      max_depth:
        type: int
        default: 6
    command: "python modelling.py --data_path {data_path} --n_estimators {n_estimators} --max_depth {max_depth}"
